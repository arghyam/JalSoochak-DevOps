# .env.example
# Jalsoochak V2 Docker Compose Environment Variables


# ==========================================
# Database Credentials
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ==========================================
# Minio Settings (Object Storage)
# ==========================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

# ==========================================
# Keycloak Local Config
# ==========================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ==========================================
# Application Integrations
# ==========================================
MAIL_ID=dummy@example.com
MAIL_USERNAME=dummy@example.com
MAIL_PASSWORD=dummypassword

GLIFIC_USERNAME=dummy_glific_user
GLIFIC_PASSWORD=dummy_glific_password

# ==========================================
# Keycloak application credentials
# ==========================================
# Keycloak realm keys
KEYCLOAK_PUBLIC_KEY=replace_with_public_key

# Keycloak client secrets
KEYCLOAK_CREDENTIAL_SECRET=replace_with_client_secret
KEYCLOAK_ADMIN_CLIENT_SECRET=replace_with_admin_client_secret
